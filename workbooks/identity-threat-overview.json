  "items": [
    {
      "id": "bc90d9ff-e744-4103-ac6a-fddf5aef5d9f",
      "type": 3,
      "name": "query - 0",
      "content": {
        "version": "KqlItem/1.0",
        "query": "AuditLogs\r\n| summarize EventCount = count() by bin(TimeGenerated, 1h)\r\n| order by TimeGenerated asc",
        "size": 0,
        "timeContext": {
          "durationMs": 604800000
        },
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "crossComponentResources": [
          "/subscriptions/a3ce03cf-c96b-48b3-9f76-3eebae942e08/resourceGroups/rg-lab-sentinel/providers/Microsoft.OperationalInsights/workspaces/lab-sentinel"
        ],
        "visualization": "timechart",
        "title": "Entra ID Audit Activity - Last 7 Days"
      }
    },
    {
      "id": "23097e80-ec8a-4e75-9b53-bd81da7a28c7",
      "type": 3,
      "name": "query - 1",
      "content": {
        "version": "KqlItem/1.0",
        "query": "AuditLogs\r\n| summarize EventCount = count() by OperationName\r\n| order by EventCount desc\r\n| take 10",
        "size": 0,
        "timeContext": {
          "durationMs": 604800000
        },
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "crossComponentResources": [
          "/subscriptions/a3ce03cf-c96b-48b3-9f76-3eebae942e08/resourceGroups/rg-lab-sentinel/providers/Microsoft.OperationalInsights/workspaces/lab-sentinel"
        ],
        "visualization": "piechart",
        "title": "Top Audit Operations - Last 7 Days"
      }
    },
    {
      "id": "4d21f0d1-6ac6-4492-99c1-1b7225e236bb",
      "type": 3,
      "name": "query - 2",
      "content": {
        "version": "KqlItem/1.0",
        "query": "AuditLogs\r\n| extend Actor = coalesce(\r\n    tostring(InitiatedBy.user.userPrincipalName),\r\n    tostring(InitiatedBy.app.displayName)\r\n)\r\n| where isnotempty(Actor)\r\n| summarize EventCount = count() by Actor\r\n| order by EventCount desc\r\n| take 10",
        "size": 0,
        "timeContext": {
          "durationMs": 604800000
        },
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "crossComponentResources": [
          "/subscriptions/a3ce03cf-c96b-48b3-9f76-3eebae942e08/resourceGroups/rg-lab-sentinel/providers/Microsoft.OperationalInsights/workspaces/lab-sentinel"
        ],
        "visualization": "table",
        "title": "Top Actors by Event Volume - Last 7 Days"
      }
    },
    {
      "id": "f4bb723c-b956-470f-9ab1-41539fc6aad6",
      "type": 3,
      "name": "query - 3",
      "content": {
        "version": "KqlItem/1.0",
        "query": "datatable(MitreID:string, TechniqueName:string, Tactic:string, DetectionName:string, Severity:string, Type:string, Status:string)\r\n[\r\n    \"T1136.003\", \"Create Account: Cloud Account\", \"Persistence\", \"Entra ID - User Account Creation\", \"Low\", \"Analytics Rule\", \"Active\",\r\n    \"T1098.003\", \"Account Manipulation: Additional Cloud Roles\", \"Privilege Escalation\", \"Entra ID - Role Assignment\", \"Medium\", \"Analytics Rule\", \"Active\",\r\n    \"T1098.001\", \"Account Manipulation: Additional Cloud Credentials\", \"Persistence\", \"Service Principal Creation\", \"Informational\", \"Hunting Query\", \"Active\"\r\n]",
        "size": 0,
        "timeContext": {
          "durationMs": 86400000
        },
        "queryType": 0,
        "resourceType": "microsoft.operationalinsights/workspaces",
        "crossComponentResources": [
          "/subscriptions/a3ce03cf-c96b-48b3-9f76-3eebae942e08/resourceGroups/rg-lab-sentinel/providers/Microsoft.OperationalInsights/workspaces/lab-sentinel"
        ],
        "visualization": "table",
        "title": "MITRE ATT&CK Coverage - Identity-Focused Lab"
      }
    },
    {
      "id": "c9ab77ed-2c6a-4396-844c-a510f806ea91",
      "type": 3,
      "name": "query - 4",
      "content": {
        "version": "KqlItem/1.0",
        "query": "SecurityIncident\r\n| summarize IncidentCount = count() by Severity\r\n| order by IncidentCount desc",
        "size": 0,
        "timeContext": {
          "durationMs": 2592000000
        },
